# Server
BOT_HOST=0.0.0.0
BOT_PORT=8080
LOG_LEVEL=info
DATA_DIR=./data
SESSION_FILE_PATH=./data/sessions.json
SESSION_TTL_MINUTES=120
APP_GIT_COMMIT=
APP_BUILD_REF=

# OneBot / QQ transport
ONEBOT_MODE=reverse
ONEBOT_ACCESS_TOKEN=change-me
ONEBOT_FORWARD_WS_URL=ws://127.0.0.1:3001/onebot/v11/ws
ONEBOT_REVERSE_WS_HOST=0.0.0.0
ONEBOT_REVERSE_WS_PORT=16700
ONEBOT_REVERSE_WS_PATH=/onebot/v11/ws
ONEBOT_ALLOW_GROUP=true
ONEBOT_REQUIRE_MENTION_IN_GROUP=true
ONEBOT_ALLOW_PRIVATE=true
ONEBOT_ALLOW_GROUP_COMMANDS_WITHOUT_MENTION=false
ONEBOT_ALLOWED_GROUPS=
ONEBOT_BLOCKED_GROUPS=
ONEBOT_ALLOWED_USERS=
ONEBOT_BLOCKED_USERS=
ONEBOT_COMMAND_PREFIX=/
ONEBOT_GROUP_CONFIG_FILE=./examples/group-rules.local.json
ONEBOT_PROGRESS_MODE=message
ONEBOT_OUTBOUND_MAX_TEXT_LENGTH=1400

# AI / ACP agent bridge
# Example (repo mock agent):
# ACP_AGENT_COMMAND=node
# ACP_AGENT_ARGS_JSON=["--import","tsx","src/examples/mock-acp-agent.ts"]
#
# Example (traecli):
# ACP_AGENT_COMMAND=traecli
# ACP_AGENT_ARGS_JSON=["acp","serve"]
ACP_AGENT_COMMAND=your-acp-agent-command
ACP_AGENT_ARGS_JSON=[]
ACP_AGENT_WORKDIR=/path/to/your/workdir
ACP_CLIENT_NAME=qq-ai-bot
ACP_REUSE_SESSION=true
ACP_DEFAULT_SYSTEM_PROMPT=
ACP_VERBOSE_MODE=verbose
ACP_PROGRESS_THROTTLE_MS=800
ACP_MAX_PROGRESS_UPDATES=6
ACP_PERMISSION_STRATEGY=allow_once
ACP_MAX_INBOUND_IMAGES=3
ACP_MAX_INBOUND_IMAGE_BYTES=6291456
