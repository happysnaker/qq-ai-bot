# Server
BOT_HOST=0.0.0.0
BOT_PORT=8080
LOG_LEVEL=info
SESSION_TTL_MINUTES=120

# OneBot / QQ transport
ONEBOT_MODE=reverse
ONEBOT_ACCESS_TOKEN=change-me
ONEBOT_FORWARD_WS_URL=ws://127.0.0.1:3001/onebot/v11/ws
ONEBOT_REVERSE_WS_HOST=0.0.0.0
ONEBOT_REVERSE_WS_PORT=6700
ONEBOT_REVERSE_WS_PATH=/onebot/v11/ws
ONEBOT_REQUIRE_MENTION_IN_GROUP=true
ONEBOT_ALLOW_PRIVATE=true
ONEBOT_ALLOWED_GROUPS=
ONEBOT_ALLOWED_USERS=
ONEBOT_PROGRESS_MODE=message

# AI / ACP agent bridge
ACP_AGENT_COMMAND=codex
ACP_AGENT_ARGS_JSON=[]
ACP_AGENT_WORKDIR=/Users/bytedance/GolandProjects/DevPlan
ACP_CLIENT_NAME=qq-ai-bot
ACP_SESSION_MODE=new
ACP_REUSE_SESSION=true
ACP_VERBOSE_MODE=verbose
ACP_PROGRESS_THROTTLE_MS=800
